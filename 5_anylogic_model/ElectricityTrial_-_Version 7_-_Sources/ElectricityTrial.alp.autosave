<AnyLogicWorkspace WorkspaceVersion="1.9" AnyLogicVersion="8.9.7.202512121156" AlpVersion="8.9.7">
<Model>
	<Id>1773937537504</Id>
	<Name><![CDATA[ElectricityTrial]]></Name>
	<EngineVersion>6</EngineVersion>
	<JavaPackageName><![CDATA[model]]></JavaPackageName>
	<ModelTimeUnit><![CDATA[Month]]></ModelTimeUnit>
	<Folders>
	</Folders>
	<ActiveObjectClasses>
		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1773937537508</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[currentIndex = 0;

basePrice = 100;
if (compareCarbonTax == 0) compareCarbonTax = 50;
carbonTaxLive = compareCarbonTax;
renewableSubsidyLive = compareRenewableSubsidy;
lastCarbonTaxLive = carbonTaxLive;
lastRenewableSubsidyLive = renewableSubsidyLive;

loadGenerationData();
loadDemandData();
loadShockConfig();


grid.marketPrice = basePrice;
grid.totalDemand = 0;
grid.totalSupply = 0;
grid.gap = 0;
grid.tightness = 1.0;

traceln("month0 = " + monthList[0]);
traceln("gen0 = " + totalGenData[0]);
traceln("thermal0 = " + thermalGenData[0]);
traceln("demand0 = " + totalDemandData[0]);
traceln("primary0 = " + primaryDemandData[0]);
traceln("secondary0 = " + secondaryDemandData[0]);
traceln("tertiary0 = " + tertiaryDemandData[0]);
traceln("residential0 = " + residentialDemandData[0]);

if (useHistoricalData) {
    traceln("calling applyHistoricalMonth() from startup...");
    applyHistoricalMonth();
    traceln("after applyHistoricalMonth:");
    traceln("grid.totalDemand = " + grid.totalDemand);
    traceln("grid.totalSupply = " + grid.totalSupply);
    traceln("grid.marketPrice = " + grid.marketPrice);
} else {
    grid.clearMarket();
}

marketPriceTrialDS.reset();
renewableShareTrialDS.reset();
balanceTrialDS.reset();
marketPriceTrialDS.add(time(), grid.marketPrice);
renewableShareTrialDS.add(time(), (grid.totalSupply > 0)
        ? (hydroGen.generation + nuclearGen.generation + solarGen.generation + windGen.generation) / grid.totalSupply * 100.0
        : 0.0);
balanceTrialDS.add(time(), grid.totalSupply - grid.totalDemand);



updateDisplayStatus();
]]></StartupCode>
