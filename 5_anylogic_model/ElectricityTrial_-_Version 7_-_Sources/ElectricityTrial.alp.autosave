			<Events>
				<Event>
					<Id>1773941545291</Id>
					<Name><![CDATA[monthlyUpdate]]></Name>
					<X>-440</X><Y>750</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MONTH]]></Unit>
						</Rate>
						<Id>1773941545289</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773993600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (useHistoricalData) {
	if (currentIndex >= nMonths - 1) {
		traceln("Historical data finished at index = " + currentIndex + "; switching to forecast mode");
		useHistoricalData = false;
		currentIndex = 0;
	} else {
		currentIndex++;
		applyHistoricalMonth();
	}
}

if (!useHistoricalData) {
	if (currentIndex >= forecastMonths) {
		traceln("Forecast finished after " + currentIndex + " months.");
		finishSimulation();
		return;
	}

	currentIndex++;
	sampleSystemRandomness();

	// Keep policy sliders synchronized with GovernmentAgent each forecast step
	if (livePolicyEnabled) {
		gov.carbonTax = carbonTaxLive;
		gov.renewablePriority = 1.0 + renewableSubsidyLive;
	}

	// Demand growth: demandGrowthAdj is an annual multiplier (e.g. 1.05 = +5%/yr)
	double monthlyGrowth = Math.pow(Math.max(0.5, gov.demandGrowthAdj), 1.0 / 12.0);
	primaryDem.demand     *= monthlyGrowth;
	secondaryDem.demand   *= monthlyGrowth;
	tertiaryDem.demand    *= monthlyGrowth;
	residentialDem.demand *= monthlyGrowth;

	// Stochastic shocks also apply during forecast (ABM resilience testing)
	sampleShock();
	if (shockActive) {
		double dm = 1.0 + shockIntensity;
		primaryDem.demand     *= dm;
		secondaryDem.demand   *= dm;
		tertiaryDem.demand    *= dm;
		residentialDem.demand *= dm;
	}

	primaryDem.demand     *= demandRandomFactor;
	secondaryDem.demand   *= demandRandomFactor;
	tertiaryDem.demand    *= demandRandomFactor;
	residentialDem.demand *= demandRandomFactor;

	// Total demand (sector sum already includes shock)
	grid.totalDemand = primaryDem.demand + secondaryDem.demand
	                 + tertiaryDem.demand + residentialDem.demand;

	// Evolving renewable market shares over forecast horizon (energy transition)
	// progress: 0 at forecast start -> 1 at forecastMonths end
	double progress = currentIndex / Math.max(1.0, (double) forecastMonths);
	double rp = Math.max(0.5, Math.min(1.5, gov.renewablePriority));
	double wShare = Math.min(0.35, 0.20 + progress * 0.08 * rp);  // wind: 20% -> 28%+
	double sShare = Math.min(0.30, 0.15 + progress * 0.10 * rp);  // solar: 15% -> 25%+
	double hShare = 0.20 * shockHydroFactor;                        // hydro: 20%, shock-reduced
	double nShare = Math.min(0.25, 0.20 + progress * 0.02 * rp);  // nuclear: 20% -> 22%+
	double tShare = Math.max(0.05, 1.0 - wShare - sShare - hShare - nShare); // thermal: 25% -> min 5%

	// Carbon-tax slider suppresses thermal share so impact is visible in charts
	if (livePolicyEnabled) {
		double thermalPenalty = Math.max(0.0, Math.min(0.70, (carbonTaxLive - 50.0) / 250.0));
		tShare = Math.max(0.03, tShare * (1.0 - thermalPenalty));
	}

	// Normalize shares to ensure they sum to 1
	double totShare = wShare + sShare + hShare + nShare + tShare;
	windGen.marketShare    = wShare   / totShare;
	solarGen.marketShare   = sShare   / totShare;
	hydroGen.marketShare   = hShare   / totShare;
	nuclearGen.marketShare = nShare   / totShare;
	thermalGen.marketShare = tShare   / totShare;

	// Generation from shares
	windGen.generation    = grid.totalDemand * windGen.marketShare;
	solarGen.generation   = grid.totalDemand * solarGen.marketShare;
	hydroGen.generation   = grid.totalDemand * hydroGen.marketShare;
	nuclearGen.generation = grid.totalDemand * nuclearGen.marketShare;
	thermalGen.generation = grid.totalDemand * thermalGen.marketShare;

	thermalGen.generation *= thermalAvailability * supplyRandomFactor;
	hydroGen.generation   *= supplyRandomFactor;
	nuclearGen.generation *= supplyRandomFactor;
	windGen.generation    *= renewableAvailability * supplyRandomFactor;
	solarGen.generation   *= renewableAvailability * supplyRandomFactor;

	grid.totalSupply = windGen.generation + solarGen.generation + hydroGen.generation
	                 + nuclearGen.generation + thermalGen.generation;

	thermalGen.updateBidPrice();
	hydroGen.updateBidPrice();
	nuclearGen.updateBidPrice();
	windGen.updateBidPrice();
	solarGen.updateBidPrice();

	grid.gap       = grid.totalSupply - grid.totalDemand;
	grid.tightness = grid.totalDemand / Math.max(grid.totalSupply, 0.0001);
	grid.marketPrice = basePrice * grid.tightness * gov.priceSensitivity * priceRandomFactor;
	if (grid.marketPrice < 100) grid.marketPrice = 100;

	thermalGen.updateProfit();
	hydroGen.updateProfit();
	nuclearGen.updateProfit();
	windGen.updateProfit();
	solarGen.updateProfit();
}

if (livePolicyEnabled) {
	applyLivePolicyDispatchAdjustments();

	grid.totalSupply = thermalGen.generation + hydroGen.generation
	                + nuclearGen.generation + windGen.generation + solarGen.generation;

	double den = Math.max(grid.totalDemand, 0.0001);
	thermalGen.marketShare = thermalGen.generation / den;
	hydroGen.marketShare = hydroGen.generation / den;
	nuclearGen.marketShare = nuclearGen.generation / den;
	windGen.marketShare = windGen.generation / den;
	solarGen.marketShare = solarGen.generation / den;

	thermalGen.updateBidPrice();
	hydroGen.updateBidPrice();
	nuclearGen.updateBidPrice();
	windGen.updateBidPrice();
	solarGen.updateBidPrice();

	grid.gap = grid.totalSupply - grid.totalDemand;
	grid.tightness = grid.totalDemand / Math.max(grid.totalSupply, 0.0001);
	grid.marketPrice = Math.max(100, basePrice * grid.tightness * gov.priceSensitivity * priceRandomFactor);

	thermalGen.updateProfit();
	hydroGen.updateProfit();
	nuclearGen.updateProfit();
	windGen.updateProfit();
	solarGen.updateProfit();
}

marketPriceTrialDS.add(time(), grid.marketPrice);
renewableShareTrialDS.add(time(), (grid.totalSupply > 0)
		? (hydroGen.generation + nuclearGen.generation + solarGen.generation + windGen.generation) / grid.totalSupply * 100.0
		: 0.0);
balanceTrialDS.add(time(), grid.totalSupply - grid.totalDemand);

updateDisplayStatus();
]]></Action>
				</Event>
				<Event>
					<Id>1777736292367</Id>
					<Name><![CDATA[flowAnim]]></Name>
					<X>-440</X><Y>790</Y>
