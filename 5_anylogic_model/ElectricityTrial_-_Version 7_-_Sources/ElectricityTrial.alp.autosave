				<Event>
					<Id>1777747000201</Id>
					<Name><![CDATA[policySliderWatcher]]></Name>
					<X>-450</X><Y>830</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MONTH]]></Unit>
						</Rate>
						<Id>1777747000200</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1777795200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!livePolicyEnabled) return;

if (Math.abs(carbonTaxLive - lastCarbonTaxLive) > 1e-9
 || Math.abs(renewableSubsidyLive - lastRenewableSubsidyLive) > 1e-9) {
	onPolicySliderChanged();
	lastCarbonTaxLive = carbonTaxLive;
	lastRenewableSubsidyLive = renewableSubsidyLive;
}]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773988141945</Id>
					<Name><![CDATA[updateDisplayStatus]]></Name>
					<X>-1120</X><Y>1180</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[String displayMonth;
String phaseLabel;
String progressLabel;
int phaseDone;
int phaseTotal;
int phaseRemaining;
int overallDone;
int overallTotal = nMonths + forecastMonths;
double overallPct;
java.util.function.Function<java.time.LocalDate, String> fmtYM = d -> d.getYear() + "." + d.getMonthValue();

int lastMonthIndex = -1;
for (int i = nMonths - 1; i >= 0; i--) {
	if (monthList[i] != null && monthList[i].length() >= 10) {
		lastMonthIndex = i;
		break;
	}
}

if (useHistoricalData) {
	int safeIndex = Math.max(0, Math.min(currentIndex, nMonths - 1));
	String rawMonth = monthList[safeIndex];
	if (rawMonth != null && rawMonth.length() >= 10) {
		java.time.LocalDate histMonth = java.time.LocalDate.parse(rawMonth.substring(0, 10));
		displayMonth = fmtYM.apply(histMonth);
	} else {
		displayMonth = "2010.1";
	}
	phaseLabel = "Historical";
	phaseDone = safeIndex + 1;
	phaseTotal = nMonths;
	phaseRemaining = Math.max(0, phaseTotal - phaseDone);
	overallDone = phaseDone;
} else {
	java.time.LocalDate forecastBaseMonth;
	if (lastMonthIndex >= 0) {
		forecastBaseMonth = java.time.LocalDate.parse(monthList[lastMonthIndex].substring(0, 10)).plusMonths(currentIndex);
	} else {
		forecastBaseMonth = java.time.LocalDate.of(2026, 1, 1).plusMonths(Math.max(0, currentIndex - 1));
	}
	displayMonth = fmtYM.apply(forecastBaseMonth) + " *";
	phaseLabel = "Forecast";
	phaseDone = currentIndex;
	phaseTotal = forecastMonths;
	phaseRemaining = Math.max(0, phaseTotal - phaseDone);
	overallDone = nMonths + phaseDone;
}

overallPct = overallTotal <= 0 ? 0.0 : (100.0 * overallDone / overallTotal);
progressLabel = "Phase = " + phaseLabel
	+ " | Step = " + phaseDone + "/" + phaseTotal
	+ " | Remaining = " + phaseRemaining
	+ " | Overall = " + overallDone + "/" + overallTotal
	+ " (" + String.format("%.1f", overallPct) + "%)";

textMonth.setText("Time = " + displayMonth);
textPrice.setText("Price = " + String.format("%.2f", grid.marketPrice));
textStatus.setText(progressLabel);
textLegend.setText("* forecast period | 3D reports auto-open in browser");
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773988141945</Id>
					<Name><![CDATA[loadGenerationData]]></Name>
					<X>-1120</X><Y>1220</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
        int i = 0;

        java.util.List<com.querydsl.core.Tuple> rows = selectFrom(generation).list(
            generation.date,
            generation.total_gen,
            generation.thermal_gen,
            generation.hydro_gen,
            generation.nuclear_gen,
            generation.wind_gen,
            generation.solar_gen
        );

        for (com.querydsl.core.Tuple row : rows) {
            if (i >= nMonths) break;

            String d = String.valueOf(row.get(generation.date));

            monthList[i] = d;
            totalGenData[i] = row.get(generation.total_gen);
            thermalGenData[i] = row.get(generation.thermal_gen);
            hydroGenData[i] = row.get(generation.hydro_gen);
            nuclearGenData[i] = row.get(generation.nuclear_gen);
            windGenData[i] = row.get(generation.wind_gen);
            solarGenData[i] = row.get(generation.solar_gen);

            i++;
        }

        traceln("Generation loaded: " + i);

    } catch (Exception e) {
        traceln("Error loading generation: " + e);
        e.printStackTrace();
    }

]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773988410723</Id>
					<Name><![CDATA[loadDemandData]]></Name>
					<X>-1120</X><Y>1260</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
        int i = 0;

        java.util.List<com.querydsl.core.Tuple> rows = selectFrom(demand).list(
            demand.date,
            demand.total_demand,
            demand.primary_demand,
            demand.secondary_demand,
            demand.tertiary_demand,
            demand.residential_demand
        );

        for (com.querydsl.core.Tuple row : rows) {
            if (i >= nMonths) break;

			String d = String.valueOf(row.get(demand.date));
			if (monthList[i] == null) {
				monthList[i] = d;
			}

            totalDemandData[i] = row.get(demand.total_demand);
            primaryDemandData[i] = row.get(demand.primary_demand);
            secondaryDemandData[i] = row.get(demand.secondary_demand);
            tertiaryDemandData[i] = row.get(demand.tertiary_demand);
            residentialDemandData[i] = row.get(demand.residential_demand);

            i++;
        }

        traceln("Demand loaded: " + i);

    } catch (Exception e) {
        traceln("Error loading demand: " + e);
        e.printStackTrace();
    }

]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1777747400200</Id>
					<Name><![CDATA[sampleSystemRandomness]]></Name>
					<X>-1120</X><Y>1425</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[demandRandomFactor = Math.max(0.85, Math.min(1.20, normal(1.0, 0.04)));
supplyRandomFactor = Math.max(0.80, Math.min(1.20, normal(1.0, 0.05)));
thermalAvailability = Math.max(0.70, Math.min(1.00, normal(0.95, 0.05)));
renewableAvailability = Math.max(0.60, Math.min(1.25, normal(1.0, 0.10)));
priceRandomFactor = Math.max(0.85, Math.min(1.25, normal(1.0, 0.06)));
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1774100000013</Id>
					<Name><![CDATA[loadShockConfig]]></Name>
					<X>-1120</X><Y>1460</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Shock parameter table
// Fields: shock_type, base_prob, intensity_mean, intensity_std, recovery_months, hydro_capacity_factor
// + shockProbJitterList : monthly probability jitter amplitude

// extreme_weather: demand surge and hydro constraint (drought / flood)
shockTypeList[0]           = "extreme_weather";
shockProbList[0]           = 0.05;
shockProbJitterList[0]     = 0.30;
shockIntensityMeanList[0]  = 0.15;
shockIntensityStdList[0]   = 0.05;
shockRecoveryMonthsList[0] = 6;
shockHydroFactorList[0]    = 0.70;

// policy_shift: policy and carbon uncertainty
shockTypeList[1]           = "policy_shift";
shockProbList[1]           = 0.03;
shockProbJitterList[1]     = 0.25;
shockIntensityMeanList[1]  = 0.08;
shockIntensityStdList[1]   = 0.03;
shockRecoveryMonthsList[1] = 12;
shockHydroFactorList[1]    = 1.00;

// supply_disruption: outage / maintenance shock
shockTypeList[2]           = "supply_disruption";
shockProbList[2]           = 0.04;
shockProbJitterList[2]     = 0.35;
shockIntensityMeanList[2]  = 0.12;
shockIntensityStdList[2]   = 0.04;
shockRecoveryMonthsList[2] = 4;
shockHydroFactorList[2]    = 0.85;

// demand_surge: weather-driven peak load
shockTypeList[3]           = "demand_surge";
shockProbList[3]           = 0.06;
shockProbJitterList[3]     = 0.20;
shockIntensityMeanList[3]  = 0.18;
shockIntensityStdList[3]   = 0.06;
shockRecoveryMonthsList[3] = 3;
shockHydroFactorList[3]    = 1.00;

shockProbabilityRegime = 1.0;
sampleSystemRandomness();
traceln("Shock config initialized: 4 types (randomized probabilities/intensity/recovery enabled)");
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1774100000014</Id>
					<Name><![CDATA[sampleShock]]></Name>
					<X>-1120</X><Y>1500</Y>
					<Label><X>19</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Slowly-varying regime causes clustered calm/storm periods in probabilities
shockProbabilityRegime = Math.max(0.70, Math.min(1.50,
        0.85 * shockProbabilityRegime + 0.15 * normal(1.0, 0.25)));

// --- recovery phase: randomized path (not fixed exponential) ---
if (shockActive) {
    shockRemainingMonths--;
    if (shockRemainingMonths <= 0) {
        shockIntensity   = 0.0;
        shockHydroFactor = 1.0;
        shockActive      = false;
        traceln("Shock ended at month " + currentIndex);
    } else {
        // Randomized decay speed each month
        double decay = Math.max(0.55, Math.min(0.95, 0.80 + normal(0.0, 0.06)));
        double hydroDecay = Math.max(0.50, Math.min(0.95, decay + normal(0.0, 0.04)));
        shockIntensity   *= decay;
        shockHydroFactor  = 1.0 - (1.0 - shockHydroFactor) * hydroDecay;
    }
    return;
}

// --- onset phase: probability and intensity are both stochastic ---
for (int k = 0; k < 4; k++) {
    double jitteredProb = shockProbList[k] * shockProbabilityRegime * (1.0 + normal(0.0, shockProbJitterList[k]));
    jitteredProb = Math.max(0.0, Math.min(0.90, jitteredProb));

    if (uniform(1.0) < jitteredProb) {
        // Heavy-tail intensity: baseline normal + occasional extra burst
        double raw = normal(shockIntensityMeanList[k], shockIntensityStdList[k]);
        if (uniform(1.0) < 0.20) {
            raw += uniform(0.5, 1.5) * shockIntensityStdList[k];
        }

        shockIntensity        = Math.max(0.01, Math.min(0.60, raw));
        shockActive           = true;
        shockRemainingMonths  = shockRecoveryMonthsList[k];
        shockHydroFactor      = shockHydroFactorList[k];

        traceln("SHOCK fired at month " + currentIndex
            + ": type=" + shockTypeList[k]
            + "  p=" + String.format("%.3f", jitteredProb)
            + "  regime=" + String.format("%.3f", shockProbabilityRegime)
            + "  intensity=" + String.format("%.3f", shockIntensity)
            + "  duration=" + shockRemainingMonths + "mo");
        break;  // at most one shock type active at a time
    }
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773988663681</Id>
					<Name><![CDATA[applyHistoricalMonth]]></Name>
					<X>-1120</X><Y>1360</Y>
					<Label><X>20</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (currentIndex < 0 || currentIndex >= nMonths) {
    traceln("applyHistoricalMonth skipped: currentIndex = " + currentIndex
            + ", nMonths = " + nMonths);
    return;
}


traceln(">>> applyHistoricalMonth called, currentIndex = " + currentIndex);

if (currentIndex >= nMonths) {
    traceln("Historical data finished.");
    return;
}

// demand (baseline from historical data)
grid.totalDemand = totalDemandData[currentIndex];

primaryDem.demand     = primaryDemandData[currentIndex];
secondaryDem.demand   = secondaryDemandData[currentIndex];
tertiaryDem.demand    = tertiaryDemandData[currentIndex];
residentialDem.demand = residentialDemandData[currentIndex];

sampleSystemRandomness();

// stochastic shock: may amplify demand and constrain hydro
sampleShock();
if (shockActive) {
    double dm = 1.0 + shockIntensity;
    grid.totalDemand      *= dm;
    primaryDem.demand     *= dm;
    secondaryDem.demand   *= dm;
    tertiaryDem.demand    *= dm;
    residentialDem.demand *= dm;
}

primaryDem.demand     *= demandRandomFactor;
secondaryDem.demand   *= demandRandomFactor;
tertiaryDem.demand    *= demandRandomFactor;
residentialDem.demand *= demandRandomFactor;
grid.totalDemand = primaryDem.demand + secondaryDem.demand + tertiaryDem.demand + residentialDem.demand;

// generation (hydro scaled by shock factor for weather/disruption events)
thermalGen.generation = thermalGenData[currentIndex];
hydroGen.generation   = hydroGenData[currentIndex] * shockHydroFactor;
nuclearGen.generation = nuclearGenData[currentIndex];
windGen.generation    = windGenData[currentIndex];
solarGen.generation   = solarGenData[currentIndex];

thermalGen.generation *= thermalAvailability * supplyRandomFactor;
hydroGen.generation   *= supplyRandomFactor;
nuclearGen.generation *= supplyRandomFactor;
windGen.generation    *= renewableAvailability * supplyRandomFactor;
solarGen.generation   *= renewableAvailability * supplyRandomFactor;

// shares
thermalGen.marketShare = thermalGen.generation / Math.max(grid.totalDemand, 0.0001);
hydroGen.marketShare = hydroGen.generation / Math.max(grid.totalDemand, 0.0001);
nuclearGen.marketShare = nuclearGen.generation / Math.max(grid.totalDemand, 0.0001);
windGen.marketShare = windGen.generation / Math.max(grid.totalDemand, 0.0001);
solarGen.marketShare = solarGen.generation / Math.max(grid.totalDemand, 0.0001);

// total supply
grid.totalSupply = thermalGen.generation
                 + hydroGen.generation
                 + nuclearGen.generation
                 + windGen.generation
                 + solarGen.generation;

// bids
thermalGen.updateBidPrice();
hydroGen.updateBidPrice();
nuclearGen.updateBidPrice();
windGen.updateBidPrice();
solarGen.updateBidPrice();

// price
grid.gap = grid.totalSupply - grid.totalDemand;
grid.tightness = grid.totalDemand / Math.max(grid.totalSupply, 0.0001);

grid.marketPrice = basePrice * grid.tightness * gov.priceSensitivity * priceRandomFactor;
if (grid.marketPrice < 100) grid.marketPrice = 100;

// profits
thermalGen.updateProfit();
hydroGen.updateProfit();
nuclearGen.updateProfit();
windGen.updateProfit();
solarGen.updateProfit();

// text
updateDisplayStatus();

// console
traceln("month=" + monthList[currentIndex]
    + ", demand=" + grid.totalDemand
    + ", supply=" + grid.totalSupply
    + ", price=" + grid.marketPrice);

traceln("<<< applied month = " + monthList[currentIndex]
    + ", demand = " + grid.totalDemand
    + ", supply = " + grid.totalSupply
    + ", price = " + grid.marketPrice);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1777746267333</Id>
					<Name><![CDATA[applyLivePolicyDispatchAdjustments]]></Name>
					<X>-1110</X><Y>1540</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[
	if (!livePolicyEnabled) return;

    // Keep government policy parameters synced with sliders
    gov.carbonTax = carbonTaxLive;
    gov.renewablePriority = 1.0 + renewableSubsidyLive; // affects existing bid discount logic

    // Read current generation mix
    double t = thermalGen.generation;
    double h = hydroGen.generation;
    double n = nuclearGen.generation;
    double w = windGen.generation;
    double s = solarGen.generation;

    double oldTotal = t + h + n + w + s;
    if (oldTotal <= 0) return;

    // 1) Carbon tax penalizes thermal generation (higher tax, smaller thermal share)
    double thermalPenalty = Math.max(0.0, Math.min(0.70, (carbonTaxLive - 50.0) / 250.0));
    t = t * (1.0 - thermalPenalty);

    // 2) Subsidy boosts wind/solar competitiveness (higher subsidy, larger renewable share)
    double renBoost = 1.0 + 0.9 * Math.max(0.0, renewableSubsidyLive);
    w = w * renBoost;
    s = s * renBoost;

    // Keep total supply unchanged under policy reallocation (adjust structure only)
    double newTotal = t + h + n + w + s;
    if (newTotal > 0) {
        double k = oldTotal / newTotal;
        t *= k; h *= k; n *= k; w *= k; s *= k;
    }

    thermalGen.generation = t;
    hydroGen.generation = h;
    nuclearGen.generation = n;
    windGen.generation = w;
    solarGen.generation = s;
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1777746299626</Id>
					<Name><![CDATA[onPolicySliderChanged]]></Name>
					<X>-1120</X><Y>1590</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[
    if (useHistoricalData) {
        applyHistoricalMonth();   // recompute current month immediately
    }

    // Forecast phase: recompute once from the current month state
    applyLivePolicyDispatchAdjustments();

    grid.totalSupply = thermalGen.generation + hydroGen.generation
            + nuclearGen.generation + windGen.generation + solarGen.generation;

    double den = Math.max(grid.totalDemand, 0.0001);
    thermalGen.marketShare = thermalGen.generation / den;
    hydroGen.marketShare = hydroGen.generation / den;
    nuclearGen.marketShare = nuclearGen.generation / den;
    windGen.marketShare = windGen.generation / den;
    solarGen.marketShare = solarGen.generation / den;

    thermalGen.updateBidPrice();
    hydroGen.updateBidPrice();
    nuclearGen.updateBidPrice();
    windGen.updateBidPrice();
    solarGen.updateBidPrice();

    grid.gap = grid.totalSupply - grid.totalDemand;
    grid.tightness = grid.totalDemand / Math.max(grid.totalSupply, 0.0001);
    grid.marketPrice = Math.max(100, basePrice * grid.tightness * gov.priceSensitivity);

    thermalGen.updateProfit();
    hydroGen.updateProfit();
    nuclearGen.updateProfit();
    windGen.updateProfit();
    solarGen.updateProfit();

    updateDisplayStatus();
]]></Body>
				</Function>
			</Functions>
