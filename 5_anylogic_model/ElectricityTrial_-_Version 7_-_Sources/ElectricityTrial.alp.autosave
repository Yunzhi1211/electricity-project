			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773939922069</Id>
					<Name><![CDATA[clearMarket]]></Name>
					<X>60</X><Y>340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[totalDemand = main.primaryDem.demand
            + main.secondaryDem.demand
            + main.tertiaryDem.demand
            + main.residentialDem.demand;

main.thermalGen.updateBidPrice();
main.hydroGen.updateBidPrice();
main.nuclearGen.updateBidPrice();
main.solarGen.updateBidPrice();
main.windGen.updateBidPrice();

main.windGen.marketShare = 0.20;
main.solarGen.marketShare = 0.15;
main.hydroGen.marketShare = 0.20;
main.nuclearGen.marketShare = 0.20;
main.thermalGen.marketShare = 0.25;

main.windGen.generation = totalDemand * main.windGen.marketShare;
main.solarGen.generation = totalDemand * main.solarGen.marketShare;
main.hydroGen.generation = totalDemand * main.hydroGen.marketShare;
main.nuclearGen.generation = totalDemand * main.nuclearGen.marketShare;
main.thermalGen.generation = totalDemand * main.thermalGen.marketShare;

totalSupply = main.windGen.generation
            + main.solarGen.generation
            + main.hydroGen.generation
            + main.nuclearGen.generation
            + main.thermalGen.generation;

gap = totalSupply - totalDemand;
tightness = totalDemand / Math.max(totalSupply, 0.0001);

marketPrice = main.basePrice * tightness;
if (marketPrice < 100) marketPrice = 100;
]]></Body>
				</Function>
			</Functions>
